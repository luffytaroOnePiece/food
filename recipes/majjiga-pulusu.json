    },
    {
      "id": "stage-1779090832178-v6xqm",
      "name": "Prepare the Curd Base",
      "cards": [
        {
          "id": "card-1779090921492-11",
          "type": "step",
          "text": "In your bowl, add half cup of curd and add the salt right now. Whisk (chilk) them together thoroughly until smooth. Slowly blend with 100ml cup of water to create your seasoned curd base."
        }
      ]
    },
    {
      "id": "stage-1779090977993-g99jb",
      "name": "Fry the Spices and Aromatics",
      "cards": [
        {
          "id": "card-1779091005110-13",
          "type": "step",
          "text": "Heat 1 teaspoon of oil in a small pan or ladle. Add the mustard seeds, cumin seeds, chana dal, urad dal, and dry red chilli. Let them splutter."
        }
      ]
    },
    {
      "id": "stage-1779091024059-3ej1s",
      "name": "Sauté the Crushed Ginger & Chilli",
      "cards": [
        {
          "id": "card-1779091038376-15",
          "type": "step",
          "text": "Add the crushed ginger and green chilli directly into the hot oil. Sauté for a few seconds until the raw aroma disappears and infuses into the oil."
        }
      ]
    },
    {
      "id": "stage-1779091054659-943u7",
      "name": "Toss the Onions",
      "cards": [
        {
          "id": "card-1779091071859-17",
          "type": "step",
          "text": "Add the sliced onions and curry leaves to the pan. Sauté for about 30 seconds so the onions soften slightly but keep their crunch. Stir in the turmeric powder"
        }
      ]
    },
    {
      "id": "stage-1779091129175-be458",
      "name": "Pour and Heat",
      "cards": [
        {
          "id": "card-1779091133542-18",
          "type": "step",
          "text": "Pour the prepared salted curd base directly into the pan with the hot tempering. Turn the stove to low heat and cook for exactly 3 minutes, stirring constantly so the curd warms through evenly and doesn't split.",
          "timerMinutes": 3
        }
      ]
    },
    {
      "id": "stage-1779091158674-f4whi",
      "name": "Garnish & Serve",
      "cards": [
        {
          "id": "card-1779091168358-19",
          "type": "step",
          "text": "Turn off the stove, mix in the fresh coriander leaves, and serve your warm, perfectly spiced Majjiga Charu over hot rice."
        }
      ]
    },
