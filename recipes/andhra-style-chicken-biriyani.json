    {
      "id": "stage-1777947588177-3g7n9",
      "name": "Marinate chicken",
      "cards": [
        {
          "id": "card-1777947598075-8",
          "type": "step",
          "text": "Mix:\n\nChicken,\nCurd,\nGinger garlic paste,\nChilli powder,\nTurmeric,\nSalt,\nBiriyani powder,\nLemon juice,\nLittle oil\n\n& Rest 30–60 mins minimum (longer = better flavor)",
          "timerMinutes": 60
        }
      ]
    },
    {
      "id": "stage-1777947786061-onbtt",
      "name": "Base preparation",
      "cards": [
        {
          "id": "card-1777947804093-9",
          "type": "step",
          "text": "Heat a thick pot and add 🥄 oil with 🍯 ghee. Fry 🍽️ cashews and keep them aside. In the same pot, add 🪵 biriyani whole spices, then add sliced 🧅 onions and cook until they turn golden brown."
        }
      ]
    },
    {
      "id": "stage-1777947951042-71btu",
      "name": "Masala cooking",
      "cards": [
        {
          "id": "card-1777947955876-10",
          "type": "step",
          "text": "Add 🌶 green chillies and 🥣 ginger garlic paste, then sauté briefly. Add 🍅 tomatoes and cook until soft. Add 🌶 chilli powder, ✨ turmeric powder, 🥄 coriander powder, 🧂 biriyani powder, and 🧂 salt, and cook until the oil separates from the masala."
        }
      ]
    },
    {
      "id": "stage-1777948008726-yv7kk",
      "name": "Chicken cooking",
      "cards": [
        {
          "id": "card-1777948013876-11",
          "type": "step",
          "text": "Add the marinated 🐔 chicken and cook on medium flame until it is about 70% done. Add 🌿 mint leaves, 🍃 coriander leaves, and crushed 🌿 kasuri methi, then mix well."
        }
      ]
    },
    {
      "id": "stage-1777948084793-jnygu",
      "name": "Rice layering",
      "cards": [
        {
          "id": "card-1777948090325-12",
          "type": "step",
          "text": "Add soaked rice into the pot and pour water (around 1:2 ratio). Adjust salt. Top with 🍯 ghee, fried 🍽️ cashews, and a little more 🌿 mint and 🍃 coriander."
        }
      ]
    },
    {
      "id": "stage-1777948123324-sc9i6",
      "name": "cooking",
      "cards": [
        {
          "id": "card-1777948131643-13",
          "type": "step",
          "text": "Cover the pot tightly and cook on low flame for 15–20 minutes until the rice is fully cooked and aromatic."
        }
      ]
    },
    {
      "id": "stage-1777948155991-9bxgu",
      "name": "Finishing",
      "cards": [
        {
          "id": "card-1777948162942-14",
          "type": "step",
          "text": "Switch off the flame and let the biryani rest covered for 5–10 minutes. Gently mix before serving."
        }
      ]
    },
