    {
      "id": "stage-1778493557809-dmrw6",
      "name": "Preparation & Soaking",
      "cards": [
        {
          "id": "card-1778498373262-25",
          "type": "step",
          "text": "First, take 0.5 cup Rice 🍚, 0.5 cup Toor Dal 🫘, 0.5 cup Moong Dal 🥣, and 0.5 cup Masoor Dal 🥣 in a large bowl."
        },
        {
          "id": "card-1778498389146-26",
          "type": "step",
          "text": "Wash them thoroughly under clean water 💧 2-3 times to remove any dust."
        },
        {
          "id": "card-1778498406328-27",
          "type": "step",
          "text": "Wash them thoroughly under clean water 💧 2-3 times to remove any dust."
        }
      ]
    },
    {
      "id": "stage-1778498410478-atctt",
      "name": "Sautéing the Aromatics",
      "cards": [
        {
          "id": "card-1778498638907-28",
          "type": "step",
          "text": "Place a pressure cooker ⚙️ on the stove and add 2 tbsp Oil  to heat it up."
        },
        {
          "id": "card-1778498652658-29",
          "type": "step",
          "text": "Once the oil heats up, toss in 0.5 piece Biryani Leaves 🍃, 0.5 piece Cinnamon Stick 🪵, 1 piece Cardamom 🍽️, 1 piece Cloves 🍽️, and 1 tsp Cumin Seeds 🍽️."
        },
        {
          "id": "card-1778498668640-30",
          "type": "step",
          "text": "Fry them for a few seconds until they release a wonderful aroma 👃✨."
        },
        {
          "id": "card-1778498684657-32",
          "type": "step",
          "text": "Add 1 chopped Onion 🧅 and sauté until it turns a light golden brown color."
        },
        {
          "id": "card-1778498692791-33",
          "type": "step",
          "text": "Stir in 0.5 tsp Ginger Garlic Paste 🥣 and 2 slit Green Chillies 🍽️, frying until the raw smell disappears."
        }
      ]
    },
    {
      "id": "stage-1778498705706-q65s6",
      "name": "Spices & Veggie Base",
      "cards": [
        {
          "id": "card-1778498715906-34",
          "type": "step",
          "text": "Add 1 chopped Tomato 🍅 and cook until it becomes soft and mushy."
        },
        {
          "id": "card-1778498723407-35",
          "type": "step",
          "text": "Lower the flame and sprinkle in 0.5 tsp Turmeric Powder ✨, 1 tsp Chili Powder 🌶️, 0.5 tsp Coriander Powder 🍽️, 0.5 tsp Garam Masala 🍽️, and some Salt 🧂."
        },
        {
          "id": "card-1778498731222-36",
          "type": "step",
          "text": "Mix everything well for a minute so the spices 🌶️ blend perfectly with the base."
        }
      ]
    },
    {
      "id": "stage-1778498739874-ypk4c",
      "name": "Pressure Cooking",
      "cards": [
        {
          "id": "card-1778498750189-37",
          "type": "step",
          "text": "Drain the water from the soaked rice and dals 🍚🫘🥣 and add them into the cooker."
        },
        {
          "id": "card-1778498769240-38",
          "type": "step",
          "text": "Mix gently for a minute so the grains are coated in masala and spices."
        },
        {
          "id": "card-1778498789423-39",
          "type": "step",
          "text": "Pour in sufficient water 💧 (about 4 cups for a soft consistency) and add half of the 5 bunches of Coriander 🍃 (finely chopped)."
        },
        {
          "id": "card-1778498808121-40",
          "type": "step",
          "text": "Close the lid 🔒 and pressure cook for 2-3 whistles on medium flame until the khichdi is very soft."
        }
      ]
    },
    {
      "id": "stage-1778498815704-dszl3",
      "name": "The Final Tadka (Tempering)",
      "cards": [
        {
          "id": "card-1778498824589-41",
          "type": "step",
          "text": "In a small pan 🍳, heat a little more ghee and fry 3 pieces of chopped Garlic 🧄 until they turn dark golden."
        },
        {
          "id": "card-1778498837822-42",
          "type": "step",
          "text": "Add 1 Dried Red Chilli 🌶️, 10 pieces of Cashews 🍽️, and 1 tsp Inguva (Asafoetida) 🧂 for that classic flavor."
        },
        {
          "id": "card-1778498845356-43",
          "type": "step",
          "text": "Pour this sizzling tempering 🔥 directly over the cooked khichdi and cover with a lid immediately to trap the scent."
        },
        {
          "id": "card-1778498854172-44",
          "type": "step",
          "text": "Garnish with the remaining fresh Coriander 🍃 and serve your delicious meal hot! 😋🥘"
        }
      ]
    },
