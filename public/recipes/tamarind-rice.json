    {
      "id": "stage-1777196844258-fkkz1",
      "name": "Cooking Process",
      "cards": [
        {
          "id": "card-1777196859541-14",
          "type": "step",
          "text": "Soak 100g of tamarind in hot water to extract a thick pulp. Boil this pulp in a pan with turmeric, salt, and a little oil until it thickens into a paste and the oil separates.",
          "timerMinutes": 15
        },
        {
          "id": "card-1777196913675-15",
          "type": "note",
          "text": "Above step is optional if you have tamarind paste",
          "color": "pink"
        },
        {
          "id": "card-1777196997408-16",
          "type": "step",
          "text": "Cook the rice with 1 tbsp of oil & 1/2 tbsp of turmeric in the cooker to ensure the grains stay perfectly separate. Once done, spread it out on a wide plate.",
          "timerMinutes": 15
        },
        {
          "id": "card-1777197121125-17",
          "type": "step",
          "text": "In a separate pan, heat 2–3 tbsp of oil. Fry the 2 tbsp groundnuts and 7 cashews until golden. Add the 2 tbsp tempering spices (mustard, urad dal, chana dal), 2 green chilies,  2 dried red chillies, ginger slices, and 7 curry leaves , salt & turmeric",
          "timerMinutes": 5
        },
        {
          "id": "card-1777197172025-18",
          "type": "step",
          "text": "Lower the heat and add the 2 tbsp tamarind paste",
          "timerMinutes": 2
        },
        {
          "id": "card-1777197191775-19",
          "type": "step",
          "text": "Stir the mixture for 1–2 minutes until the tamarind paste is well-incorporated. Add the 0.5 tbsp Inguva at the very end so its aroma stays strong.",
          "timerMinutes": 2
        },
        {
          "id": "card-1777197239475-20",
          "type": "step",
          "text": "Pour this entire pulihora mix over the cooked rice. Toss in the coriander and mix gently until every grain of rice is yellow and coated.",
          "timerMinutes": 2
        }
      ]
    },
