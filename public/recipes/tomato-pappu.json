    {
      "id": "stage-1777192728135-5gehc",
      "name": "Cooking Process",
      "cards": [
        {
          "id": "card-1777192733352-12",
          "type": "step",
          "text": "Wash Toor dal and add it to a pressure cooker with chopped 🧅 onions, 🍅 tomatoes,  green chillies, ✨ turmeric, 🧂 salt, chilli powder, 1 tablespoon oil, and enough water. Pressure cook until soft (about 4–5 whistles).\n",
          "timerMinutes": 20
        },
        {
          "id": "card-1777192920519-1",
          "type": "note",
          "text": "Let the pressure release naturally, allow it to cool, and open the cooker after 10 minutes.",
          "color": "blue"
        },
        {
          "id": "card-1777192991803-2",
          "type": "step",
          "text": "Mash the cooked dal mixture well. Add 🧂 salt, 🥣 tamarind paste, and adjust water for your preferred consistency. Let it simmer for 5–10 minutes.",
          "timerMinutes": 10
        },
        {
          "id": "card-1777193129169-3",
          "type": "step",
          "text": "Heat 🥄 oil  or ghee (mix both for authentic taste) , add 🍽️ tempering spices, 🌶 dried red chillies, mashed 🧄 garlic cloves, 🌿 curry leaves, and let them splutter.",
          "timerMinutes": 4
        },
        {
          "id": "card-1777193231136-4",
          "type": "step",
          "text": "Pour this tempering over the dal. Add 🍃 coriander leaves, mix well, and simmer 2 more minutes.",
          "timerMinutes": 3
        },
        {
          "id": "card-1777193297769-8",
          "type": "note",
          "text": "Serve hot with rice and ghee. Classic Andhra comfort food.",
          "color": "blue"
        }
      ]
    },
