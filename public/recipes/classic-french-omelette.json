{
  "id": "classic-french-omelette",
  "meta": {
    "name": "Classic French Omelette",
    "description": "Buttery, barely-set, and impossibly elegant — the true test of technique.",
    "cuisine": "French",
    "servings": 1,
    "prepTime": 2,
    "cookTime": 3,
    "tags": ["eggs", "classic", "quick", "technique"],
    "icon": "🥚",
    "coverImage": "",
    "createdAt": "2025-04-10T09:00:00Z",
    "updatedAt": "2025-04-10T09:00:00Z"
  },
  "stages": [
    {
      "id": "stage-prep",
      "name": "Prep",
      "cards": [
        {
          "id": "fo1",
          "type": "ingredient",
          "name": "Eggs",
          "quantity": 3,
          "unit": "whole",
          "notes": "Room temperature"
        },
        {
          "id": "fo2",
          "type": "ingredient",
          "name": "Butter",
          "quantity": 1,
          "unit": "tbsp",
          "notes": "Unsalted"
        },
        {
          "id": "fo3",
          "type": "ingredient",
          "name": "Fine Salt",
          "quantity": 1,
          "unit": "pinch"
        },
        {
          "id": "fo4",
          "type": "ingredient",
          "name": "Chives",
          "quantity": 1,
          "unit": "tbsp",
          "notes": "Finely snipped"
        },
        {
          "id": "fo5",
          "type": "cookware",
          "name": "8-inch non-stick pan",
          "detail": "Must be well-seasoned or true non-stick"
        },
        {
          "id": "fo6",
          "type": "cookware",
          "name": "Fork or chopstick",
          "detail": "For stirring the curds"
        }
      ]
    },
    {
      "id": "stage-cook",
      "name": "Cook",
      "cards": [
        {
          "id": "fo7",
          "type": "step",
          "text": "Crack eggs into a bowl and beat with a fork until just combined — no air, no foam. Season with salt."
        },
        {
          "id": "fo8",
          "type": "step",
          "text": "Heat butter in the pan over medium-high heat until foamy but not brown.",
          "timerMinutes": 1
        },
        {
          "id": "fo9",
          "type": "step",
          "text": "Pour in eggs. Immediately stir with a fork in small circular motions while shaking the pan, creating small soft curds.",
          "timerMinutes": 1
        },
        {
          "id": "fo10",
          "type": "step",
          "text": "When the top is still slightly wet and creamy, stop stirring. Let it set for 10 seconds."
        },
        {
          "id": "fo11",
          "type": "note",
          "text": "The omelette should have ZERO color. If it's browning, your pan is too hot.",
          "color": "pink"
        }
      ]
    },
    {
      "id": "stage-fold",
      "name": "Fold & Plate",
      "cards": [
        {
          "id": "fo12",
          "type": "step",
          "text": "Tilt the pan and use the fork to fold the omelette in thirds — first the near edge, then roll it onto the plate seam-side down."
        },
        {
          "id": "fo13",
          "type": "step",
          "text": "Rub a cold piece of butter across the top for shine. Garnish with chives."
        },
        {
          "id": "fo14",
          "type": "note",
          "text": "The entire cooking process should take under 2 minutes. Speed is everything.",
          "color": "blue"
        }
      ]
    }
  ]
}
