    {
      "id": "stage-1778428096730-94lun",
      "name": "Prep the Rice 🍚",
      "cards": [
        {
          "id": "card-1778428108164-4",
          "type": "step",
          "text": "Cook rice with slightly less water so grains stay separate. Add little oil and 2 Cloves"
        },
        {
          "id": "card-1778428147830-5",
          "type": "note",
          "text": "Cool rice completely before frying.",
          "color": "blue"
        }
      ]
    },
    {
      "id": "stage-1778428158577-odr4s",
      "name": "Marinate the Chicken ",
      "cards": [
        {
          "id": "card-1778428219154-6",
          "type": "step",
          "text": "In a bowl, add 🐔 boneless chicken, 🧂 salt, 🌶️ chilli powder, 🧂 pepper powder, 🥣 ginger garlic paste, 🫙 soy sauce, and 🌽 corn flour. Mix everything well and let it rest for 15–20 minutes."
        },
        {
          "id": "card-1778428231521-7",
          "type": "note",
          "text": "Corn flour helps the chicken stay juicy while giving slight crispy edges during frying.",
          "color": "blue"
        }
      ]
    },
    {
      "id": "stage-1778428236788-sylui",
      "name": "Cut the vegetables 🔪",
      "cards": [
        {
          "id": "card-1778428251487-8",
          "type": "step",
          "text": "Finely chop 🧄 garlic and slice 🥕 carrot and 🫑 capsicum into thin strips/cubes. Separate the 🧅 spring onion whites and 🌱 greens. Use the whites while cooking and save the greens for garnish."
        },
        {
          "id": "card-1778428276471-9",
          "type": "note",
          "text": "Thinly sliced/cubed vegetables cook quickly and give restaurant-style texture.",
          "color": "blue"
        }
      ]
    },
    {
      "id": "stage-1778428301037-5lkg9",
      "name": "Cook the chicken",
      "cards": [
        {
          "id": "card-1778428306054-10",
          "type": "step",
          "text": "Heat 🥄 oil in a wok or pan on high flame. Add the marinated chicken and cook until it becomes slightly crispy and fully cooked. Remove and keep aside."
        },
        {
          "id": "card-1778428369503-12",
          "type": "note",
          "text": "High flame helps create smoky wok flavor and prevents the chicken from becoming watery.",
          "color": "blue"
        }
      ]
    },
    {
      "id": "stage-1778428439720-1ls6e",
      "name": "Scramble the eggs 🥚",
      "cards": [
        {
          "id": "card-1778428453269-13",
          "type": "step",
          "text": "Add little oil to the same pan and pour beaten eggs with a pinch of salt. Scramble quickly on high flame into small pieces and keep aside."
        },
        {
          "id": "card-1778428467203-14",
          "type": "note",
          "text": "Small scrambled egg pieces mix better with fried rice.",
          "color": "blue"
        }
      ]
    },
    {
      "id": "stage-1778428482335-90xnf",
      "name": "Stir fry the vegetables 🥬",
      "cards": [
        {
          "id": "card-1778428525336-15",
          "type": "step",
          "text": "Add little more oil if needed. Add 🧄 garlic and 🧅 spring onion whites first and sauté for few seconds. Then add 🥕 carrot and 🫑 capsicum. Toss on high flame for 1–2 minutes so the vegetables stay crunchy."
        },
        {
          "id": "card-1778428555653-17",
          "type": "note",
          "text": "Do not overcook the vegetables. Slight crunch gives authentic Indo-Chinese fried rice feel.",
          "color": "blue"
        }
      ]
    },
    {
      "id": "stage-1778428574636-im83m",
      "name": "Add the sauces 🌶️",
      "cards": [
        {
          "id": "card-1778428579919-18",
          "type": "step",
          "text": "Add 🌶️ Schezwan Stir Fry Sauce, 🫙 soy sauce, Green chilli sauce, 🍶 vinegar, and 🌶️ Schezwan Fried Rice Masala mix. Stir quickly on high flame until everything combines well."
        },
        {
          "id": "card-1778428669036-19",
          "type": "note",
          "text": "Too much sauce can make the rice soggy, so keep the balance light.",
          "color": "blue"
        }
      ]
    },
    {
      "id": "stage-1778428672468-zzs8j",
      "name": "Toss the rice 🍚",
      "cards": [
        {
          "id": "card-1778428761102-21",
          "type": "step",
          "text": "Add the cooked chicken, 🥚 scrambled eggs, and 🍚 cooled rice. Toss continuously on high flame until the sauces coat the rice evenly and the fried rice gets a smoky wok flavor."
        },
        {
          "id": "card-1778428777268-22",
          "type": "note",
          "text": "Toss gently so the rice grains stay separate and don’t break.",
          "color": "blue"
        }
      ]
    },
    {
      "id": "stage-1778428788102-6611l",
      "name": "Garnish and serve 🌱",
      "cards": [
        {
          "id": "card-1778428792951-23",
          "type": "step",
          "text": "Switch off the flame and garnish with 🌱 spring onion greens and 🍃 little coriander leaves. Serve hot."
        },
        {
          "id": "card-1778428806285-24",
          "type": "note",
          "text": "Adding spring onion greens at the end keeps their fresh aroma intact.",
          "color": "blue"
        }
      ]
    },
