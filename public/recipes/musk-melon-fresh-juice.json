      "name": "Prep the Fruit",
      "cards": [
        {
          "id": "card-1778562380616-5",
          "type": "step",
          "text": "🍈 First, slice the Muskmelon in half and remove the seeds before cutting the flesh into small chunks."
        },
        {
          "id": "card-1778562392283-6",
          "type": "step",
          "text": "🍯 Place the melon pieces into a blender and add 2 tablespoons of Honey/Sugar to provide a natural sweetness."
        },
        {
          "id": "card-1778562411699-7",
          "type": "step",
          "text": "💧 Pour in 200 ml of Water and blend the mixture on high speed until the texture is perfectly smooth."
        }
      ]
    },
    {
      "id": "stage-1778562419633-skx8x",
      "name": "Serve",
      "cards": [
        {
          "id": "card-1778562425466-8",
          "type": "step",
          "text": "🧊 Divide the juice into two glasses and add 3 bunches of Ice cubes to ensure the drink is refreshing and cold."
        }
      ]
    }
