    "updatedAt": "2025-04-01T10:00:00Z"
  },
  "stages": [
    {
      "id": "stage-prep",
      "name": "Prep",
      "cards": [
        {
          "id": "c1",
          "type": "ingredient",
          "name": "Guanciale",
          "quantity": 200,
          "unit": "g",
          "notes": "Dice into lardons"
        },
        {
          "id": "c2",
          "type": "ingredient",
          "name": "Spaghetti",
          "quantity": 400,
          "unit": "g"
        },
        {
          "id": "c3",
          "type": "ingredient",
          "name": "Egg Yolks",
          "quantity": 6,
          "unit": "whole",
          "notes": "Room temperature"
        },
        {
          "id": "c4",
          "type": "ingredient",
          "name": "Pecorino Romano",
          "quantity": 100,
          "unit": "g",
          "notes": "Finely grated"
        },
        {
          "id": "c5",
          "type": "ingredient",
          "name": "Black Pepper",
          "quantity": 2,
          "unit": "tsp",
          "notes": "Freshly cracked"
        },
        {
          "id": "c6",
          "type": "cookware",
          "name": "Large pot",
          "detail": "6L capacity for pasta"
        },
        {
          "id": "c7",
          "type": "cookware",
          "name": "Heavy skillet",
          "detail": "12-inch, for rendering guanciale"
        },
        {
          "id": "c8",
          "type": "note",
          "text": "Use room-temp eggs — cold eggs will scramble on contact with hot pasta.",
          "color": "yellow"
        }
      ]
    },
    {
      "id": "stage-cook",
      "name": "Cook",
      "cards": [
        {
          "id": "c9",
          "type": "step",
          "text": "Render guanciale in a cold pan over medium heat until crispy and fat has released.",
          "timerMinutes": 8
        },
        {
          "id": "c10",
          "type": "step",
          "text": "Boil pasta in heavily salted water until al dente. Reserve 1 cup pasta water before draining.",
          "timerMinutes": 10
        },
        {
          "id": "c11",
          "type": "step",
          "text": "While pasta cooks, whisk egg yolks with grated pecorino and generous black pepper in a bowl."
        },
        {
          "id": "c12",
          "type": "note",
          "text": "The pan must be OFF the heat when you add the egg mixture. Residual heat is enough.",
          "color": "pink"
        }
      ]
    },
    {
      "id": "stage-finish",
      "name": "Finish & Serve",
      "cards": [
        {
          "id": "c13",
          "type": "step",
          "text": "Remove skillet from heat. Add drained pasta to the guanciale and toss to coat in the rendered fat."
        },
        {
          "id": "c14",
          "type": "step",
          "text": "Pour the egg-cheese mixture over the pasta and toss vigorously, adding pasta water a splash at a time until silky and emulsified."
        },
        {
          "id": "c15",
          "type": "step",
          "text": "Serve immediately with extra pecorino and cracked black pepper."
        },
        {
          "id": "c16",
          "type": "note",
          "text": "Do not let the sauce sit — carbonara waits for no one. Serve the moment it's ready.",
          "color": "green"
        }
      ]
    }
  ]
}
