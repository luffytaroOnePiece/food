  "meta": {
    "name": "Spaghetti Carbonara",
    "description": "Classic Roman pasta — silky, rich, and unapologetically egg-forward.",
    "cuisine": "Italian",
    "servings": 4,
    "prepTime": 15,
    "cookTime": 20,
    "tags": ["pasta", "classic", "quick"],
